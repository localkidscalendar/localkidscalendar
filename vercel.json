{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron-process-waitlist",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron-send-notification-emails",
      "schedule": "0 15 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
