# Copy to .env.local and fill in from Supabase → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key

# Optional: API host for serverless routes when the site is opened on localhost
# or a custom domain that does not serve /api/* (defaults to vercel.app)
# VITE_API_BASE_URL=https://localkidscalendar.vercel.app

# Server-only (Vercel Project → Settings → Environment Variables — NOT Vite-prefixed)
# Required for automated ad creative review (image + link).
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_ANON_KEY=your_anon_public_key
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret
# OPENAI_API_KEY=sk-...

# Resend (admin email send via /api/send-email — server-only, never VITE-prefix)
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=Local Kids Calendar <onboarding@resend.dev>

# Stripe ads billing (server-only, never VITE-prefix). Use TEST mode keys during development.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...  (from the Stripe Dashboard webhook endpoint, or `stripe listen` locally)

# Waitlist processor cron (optional but recommended). Vercel Cron sends Authorization: Bearer <CRON_SECRET>.
# Generate any long random string and set the same value in Vercel.
# CRON_SECRET=your_long_random_secret
